msgctxt "struct:mutex:brief"
msgid "A mutex, or lock."
msgstr "Isang mutex, o lock."

msgctxt "struct:mutex:detailed"
msgid ""
"mutexes are used to prevent memory errors when two programs or threads need "
"to access the same variable."
msgstr "Ginagamit ang mga mutex upang maiwasan ang mga error sa memorya kapag dalawang programa o thread ang kailangang ma-access ang parehong variable."

msgctxt "struct:mutex:member:data:brief"
msgid "a C++ Mutex object cast to a void*. Not intended to be accessed."
msgstr "isang C++ Mutex object na in-cast sa void*. Hindi ito nilalayong ma-access."

