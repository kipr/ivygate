msgctxt "func:disable_servo:brief"
msgid "Disable a specific servo."
msgstr "I-disable ang isang partikular na servo."

msgctxt "func:disable_servo:param:port:description"
msgid "The port, between 0 and 3, to disable"
msgstr "Ang port, sa pagitan ng 0 at 3, upang huwag paganahin"

msgctxt "func:disable_servos:brief"
msgid "Disable all four servo channels."
msgstr "I-disable ang lahat ng apat na servo channel."

msgctxt "func:enable_servo:brief"
msgid "Enable a specific servo."
msgstr "I-aktiba ang isang partikular na servo."

msgctxt "func:enable_servo:param:port:description"
msgid "The port, between 0 and 3, to enable"
msgstr "Ang port, sa pagitan ng 0 at 3, upang paganahin"

msgctxt "func:enable_servos:brief"
msgid "Enable all four servo channels."
msgstr "I-aktiba ang lahat ng apat na servo channel."

msgctxt "func:extra_buttons_hide:detailed"
msgid "Hides the X, Y, and Z buttons. This is the default."
msgstr "Itinatago ang mga pindutang X, Y, at Z. Ito ang default."

msgctxt "func:extra_buttons_show:detailed"
msgid "Shows the X, Y, and Z buttons."
msgstr "Ipinapakita ang mga pindutang X, Y, at Z."

msgctxt "func:fd:brief"
msgid "Moves the given motor forward at full power."
msgstr "Ipinapagalaw ang ibinigay na motor pasulong sa buong lakas."

msgctxt "func:fd:param:motor:description"
msgid "the motor's port."
msgstr "ang daungan ng makina"

msgctxt "func:freeze:brief"
msgid "Active braking to stop a motor."
msgstr "Aktibong pagpreno upang ihinto ang isang motor."

msgctxt "func:freeze:param:motor:description"
msgid "The motor port."
msgstr "Ang daungan ng motor."

msgctxt "func:get_analog_pullup:detailed"
msgid ""
"Gets the analog pullup status for one portt. Deprecatedno effect on the "
"Wallaby"
msgstr "Kino-kuma ang analog pullup status para sa isang portt. Hindi na ginagamit; walang epekto sa Wallaby."

msgctxt "func:get_analog_pullup:param:port:description"
msgid "A value between 0 and 7 specifying the analog sensor to read from."
msgstr "Isang halaga mula 0 hanggang 7 na naglalahad kung aling analog sensor ang babasahin."

msgctxt "func:get_digital_output:detailed"
msgid "Gets the current digital mode"
msgstr "Kunin ang kasalukuyang digital na mode"

msgctxt "func:get_digital_pullup:detailed"
msgid ""
"Gets the current digital pullup state Deprecatednot applicable on the "
"Wallaby"
msgstr "Kino-kuma ang kasalukuyang estado ng digital pullup. Hindi na ginagamit; hindi naaangkop sa Wallaby."

msgctxt "func:get_digital_value:detailed"
msgid "Gets the current value of the digital port."
msgstr "Kunin ang kasalukuyang halaga ng digital na port."

msgctxt "func:get_extra_buttons_visible:detailed"
msgid "Determines whether or not the X, Y, and Z buttons are visible."
msgstr "Tinatukoy kung nakikita o hindi ang mga pindutang X, Y, at Z."

msgctxt "func:get_motor_done:brief"
msgid "Check if the motor has reached it's goal."
msgstr "Suriin kung naabot na ng motor ang layunin nito."

