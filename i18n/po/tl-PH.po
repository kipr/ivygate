msgstr "Ang daungan ng motor."

msgctxt "func:move_to_position:param:speed:description"
msgid "The speed to move at, between -1500 and 1500 ticks / second"
msgstr "Ang bilis ng paggalaw, sa pagitan ng -1500 at 1500 na tik / segundo"

msgctxt "func:mrp:brief"
