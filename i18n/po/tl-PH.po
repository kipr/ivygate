msgid "The motor port."
msgstr "Ang daungan ng motor."

msgctxt "func:cmpc:brief"
msgid "Clears the motor position counter."
msgstr "Pinapawi ang tagabibilang ng posisyon ng motor."

msgctxt "func:cmpc:param:motor:description"
msgid "The motor port."
msgstr "Ang daungan ng motor."

msgctxt "func:console_clear:detailed"
msgid "Clears the UI's console."
msgstr "Pinapawi ang console ng UI."

msgctxt "func:create_point2:brief"
msgid "Create a point2 object."
msgstr "Gumawa ng isang point2 na object."

msgctxt "func:create_point2:param:x:description"
msgid "- the x value of the point"
msgstr "- ang x na halaga ng punto"

msgctxt "func:create_point2:param:y:description"
msgid "- the y value of the point"
msgstr "- ang halagang y ng punto"

msgctxt "func:create_point3:brief"
msgid "Create a point3 object."
msgstr "Gumawa ng isang point3 na object."

msgctxt "func:create_point3:param:x:description"
msgid "- the x value of the point"
msgstr "- ang x na halaga ng punto"

msgctxt "func:create_point3:param:y:description"
msgid "- the y value of the point"
msgstr "- ang halagang y ng punto"

msgctxt "func:create_point3:param:z:description"
msgid "- the z value of the point"
msgstr "- ang halaga ng z ng punto"

msgctxt "func:create_rectangle:brief"
msgid "Create a rectangle object."
msgstr "Gumawa ng isang hugis-paralelo na bagay."

msgctxt "func:create_rectangle:param:height:description"
msgid "- the height of the rectangle"
msgstr "- ang taas ng parihaba"

msgctxt "func:create_rectangle:param:ulx:description"
