msgctxt "func:a_button:detailed"
msgid "Gets the A button's state (pressed or not pressed.)"
msgstr "Kino-kuma ang estado ng pindutang A (nakapindot o hindi nakapindot)."

msgctxt "func:a_button_clicked:detailed"
msgid "Gets the A button's state (pressed or not pressed.)"
msgstr "Kino-kuma ang estado ng pindutang A (nakapindot o hindi nakapindot)."

msgctxt "func:alloff:brief"
msgid "Turns all motors off."
msgstr "Pinapatay ang lahat ng mga motor."

msgctxt "func:analog10:detailed"
msgid "Gets the 10-bit analog value of a port."
msgstr "Kino-kuma ang 10-bit na analog na halaga ng isang port."

msgctxt "func:analog10:param:port:description"
msgid "A value between 0 and 5 specifying the sensor to read from."
msgstr "Isang halaga mula 0 hanggang 5 na naglalarawan kung aling sensor ang babasahin."

msgctxt "func:analog12:detailed"
msgid "Gets the 12-bit analog value of a port."
msgstr "Kino-kuma ang 12-bit na analog na halaga ng isang port."

msgctxt "func:analog12:param:port:description"
msgid "A value between 0 and 5 specifying the sensor to read from."
msgstr "Isang halaga mula 0 hanggang 5 na naglalahad kung aling sensor ang babasahin."

msgctxt "func:analog8:detailed"
msgid "Gets the 8-bit analog value of a port."
msgstr "Kino-kuma ang 8-bit na analog na halaga ng isang port."

msgctxt "func:analog8:param:port:description"
msgid "A value between 0 and 5 specifying the sensor to read from."
msgstr "Isang halaga mula 0 hanggang 5 na naglalarawan kung aling sensor ang babasahin."

msgctxt "func:analog:detailed"
msgid "Gets the 12-bit analog value of a port."
msgstr "Kino-kuma ang 12-bit na halagang analog ng isang port."

msgctxt "func:analog:param:port:description"
msgid "A value between 0 and 5 specifying the sensor to read from."
msgstr "Isang halaga mula 0 hanggang 5 na naglalahad kung aling sensor ang babasahin."

msgctxt "func:analog_et:detailed"
msgid ""
"Gets the 10-bit analog value of an ET sensor on the given port. "
"Deprecateddefaulting to analog() on the Wallaby"
msgstr "Kino-kuma ang 10-bit na analog na halaga ng ET sensor sa ibinigay na port. Hindi na ginagamit; awtomatikong nagde-default sa analog() sa Wallaby."

msgctxt "func:analog_et:param:port:description"
msgid "A value between 0 and 7 specifying the ET sensor to read from."
msgstr "Isang halaga sa pagitan ng 0 at 7 na naglalahad kung aling ET sensor ang babasahin."

msgctxt "func:any_button:detailed"
msgid "Determines whether or not any of the buttons are pressed."
msgstr "Tinutukoy kung may napindot na mga pindutan o wala."

msgctxt "func:ao:brief"
msgid "Turns all motors off."
msgstr "Pinapatay ang lahat ng mga motor."

msgctxt "func:b_button:detailed"
msgid "Gets the B button's state (pressed or not pressed.)"
msgstr "Kino-kuma ang estado ng B button (nakapindot o hindi nakapindot)."

msgctxt "func:b_button_clicked:detailed"
msgid "Gets the A button's state (pressed or not pressed.)"
msgstr "Kino-kuma ang estado ng pindutang A (nakapindot o hindi nakapindot)."

msgctxt "func:baasbennaguui:brief"
msgid "Moves a motor at a percent velocity."
msgstr "Ginagalaw ang isang motor sa porsyentong bilis."

msgctxt "func:baasbennaguui:param:motor:description"
msgid "The motor port."
msgstr "Ang daungan ng motor."

msgctxt "func:baasbennaguui:param:percent:description"
msgid "The percent of the motors velocity, between -100 and 100."
msgstr "Ang porsyento ng bilis ng motor, mula -100 hanggang 100."

msgctxt "func:bk:brief"
msgid "Moves the given motor backward at full power."
msgstr "Ginagalaw ang ibinigay na motor paatras sa buong lakas."

msgctxt "func:bk:param:motor:description"
msgid "the motor's port."
msgstr "ang daungan ng makina"

msgctxt "func:black_button:detailed"
msgid ""
"Gets the black button's state (pressed or not pressed.) DeprecatedNot "
"present on the Wallaby"
msgstr "Kino-kuma ang estado ng itim na pindutan (nakapindot o hindi nakapindot). Hindi na ginagamit. Hindi available sa Wallaby."

msgctxt "func:block_motor_done:brief"
msgid "Wait until the motor is at it's goal."
msgstr "Maghintay hanggang maabot ng motor ang layunin nito."

msgctxt "func:block_motor_done:param:motor:description"
msgid "The motor port."
msgstr "Ang daungan ng motor."

msgctxt "func:bmd:brief"
msgid "Wait until the motor is at it's goal."
msgstr "Maghintay hanggang maabot ng motor ang layunin nito."

msgctxt "func:bmd:param:motor:description"
msgid "The motor port."
msgstr "Ang daungan ng motor."

msgctxt "func:c_button:detailed"
