msgid "Gets the 12-bit analog value of a port."
msgstr "取得埠的 12 位元類比值。"

msgctxt "func:analog:param:port:description"
msgid "A value between 0 and 5 specifying the sensor to read from."
msgstr "介於 0 和 5 之間的值，指定要讀取的感測器。"

msgctxt "func:analog_et:detailed"
msgid ""
"Gets the 10-bit analog value of an ET sensor on the given port. "
"Deprecateddefaulting to analog() on the Wallaby"
msgstr "取得給定連接埠上 ET 感測器的 10 位元類比值。在 Wallaby 上已停用，預設為 analog()"

msgctxt "func:analog_et:param:port:description"
msgid "A value between 0 and 7 specifying the ET sensor to read from."
msgstr "介於 0 和 7 之間的值，指定要讀取的 ET 感測器。"

msgctxt "func:any_button:detailed"
msgid "Determines whether or not any of the buttons are pressed."
msgstr "決定是否按下任何按鈕。"

msgctxt "func:ao:brief"
msgid "Turns all motors off."
msgstr "關閉所有馬達。"

msgctxt "func:b_button:detailed"
msgid "Gets the B button's state (pressed or not pressed.)"
msgstr "取得 B 按鈕的狀態 (按下或未按下)。"

