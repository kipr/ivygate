msgid "The motor port."
msgstr "El puerto del motor."

msgctxt "func:baasbennaguui:param:percent:description"
msgid "The percent of the motors velocity, between -100 and 100."
msgstr "El porcentaje de la velocidad del motor, entre -100 y 100."

