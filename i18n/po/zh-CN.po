msgstr "一个介于 0 和 5 之间的值，指定要读取的传感器。"

msgctxt "func:analog_et:detailed"
msgid ""
"Gets the 10-bit analog value of an ET sensor on the given port. "
"Deprecateddefaulting to analog() on the Wallaby"
msgstr "获取给定端口上 ET 传感器的 10 位模拟值。已弃用，在 Wallaby 上默认为 analog()"

msgctxt "func:analog_et:param:port:description"
msgid "A value between 0 and 7 specifying the ET sensor to read from."
msgstr "一个介于 0 和 7 之间的值，指定要读取的蒸散发传感器。"

msgctxt "func:any_button:detailed"
msgid "Determines whether or not any of the buttons are pressed."
msgstr "确定是否按下任何按钮。"

msgctxt "func:ao:brief"
msgid "Turns all motors off."
msgstr "关闭所有电机。"

